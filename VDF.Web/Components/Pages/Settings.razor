@page "/settings"
@rendermode InteractiveServer
@inject VDF.Web.Services.ScanService Scan
@inject VDF.Web.Services.WebSettingsService WebSettings
@using System.Globalization

<PageTitle>Settings — Video Duplicate Finder</PageTitle>

<h1>Settings</h1>

<div class="start-row" style="margin-bottom:1rem;margin-top:0;">
    <button class="primary" @onclick="SaveSettings">Save Settings</button>
    @if (_saveMsg != null) {
        <span class="@(_saveFailed ? "aborted-msg" : "done-msg")" style="margin:0;">@_saveMsg</span>
    }
</div>

<section class="settings-section">
    <h2>Similarity</h2>
    <label>
        Threshold (hash difference, 0–10, lower = stricter)
        <input type="number" min="0" max="10"
               value="@Scan.Settings.Threshhold"
               @onchange="e => Scan.Settings.Threshhold = ParseByte(e.Value)" />
    </label>
    <label>
        Minimum similarity %
        <input type="number" min="0" max="100" step="0.5"
               value="@Scan.Settings.Percent.ToString(CultureInfo.InvariantCulture)"
               @onchange="e => Scan.Settings.Percent = ParseFloat(e.Value)" />
    </label>
    <label>
        Duration difference tolerance %
        <input type="number" min="0" max="100" step="1"
               value="@Scan.Settings.PercentDurationDifference.ToString(CultureInfo.InvariantCulture)"
               @onchange="e => Scan.Settings.PercentDurationDifference = ParseDouble(e.Value)" />
    </label>
</section>

<section class="settings-section">
    <h2>Scanning</h2>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.IncludeSubDirectories"
               @onchange="e => Scan.Settings.IncludeSubDirectories = (bool)e.Value!" />
        Scan subdirectories
    </label>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.IncludeImages"
               @onchange="e => Scan.Settings.IncludeImages = (bool)e.Value!" />
        Include images
    </label>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.UsePHashing"
               @onchange="e => Scan.Settings.UsePHashing = (bool)e.Value!" />
        Use perceptual hashing
    </label>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.CompareHorizontallyFlipped"
               @onchange="e => Scan.Settings.CompareHorizontallyFlipped = (bool)e.Value!" />
        Compare horizontally flipped
    </label>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.IgnoreBlackPixels"
               @onchange="e => Scan.Settings.IgnoreBlackPixels = (bool)e.Value!" />
        Ignore black pixels
    </label>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.IgnoreWhitePixels"
               @onchange="e => Scan.Settings.IgnoreWhitePixels = (bool)e.Value!" />
        Ignore white pixels
    </label>
    <label>
        Max degree of parallelism (-1 = all cores)
        <input type="number" min="-1"
               value="@Scan.Settings.MaxDegreeOfParallelism"
               @onchange="e => Scan.Settings.MaxDegreeOfParallelism = ParseInt(e.Value)" />
    </label>
    <label>
        Thumbnail count per file
        <input type="number" min="1" max="20"
               value="@Scan.Settings.ThumbnailCount"
               @onchange="e => Scan.Settings.ThumbnailCount = ParseInt(e.Value)" />
    </label>
</section>

<section class="settings-section">
    <h2>FFmpeg</h2>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.UseNativeFfmpegBinding"
               @onchange="e => Scan.Settings.UseNativeFfmpegBinding = (bool)e.Value!" />
        Use native FFmpeg binding
    </label>
    <label>
        Hardware acceleration
        <select @onchange="e => Scan.Settings.HardwareAccelerationMode = Enum.Parse<VDF.Core.FFTools.FFHardwareAccelerationMode>(e.Value!.ToString()!)">
            @foreach (var mode in Enum.GetValues<VDF.Core.FFTools.FFHardwareAccelerationMode>()) {
                <option value="@mode" selected="@(Scan.Settings.HardwareAccelerationMode == mode)">@mode</option>
            }
        </select>
    </label>
    <label>
        Custom FFmpeg arguments
        <input type="text"
               value="@Scan.Settings.CustomFFArguments"
               @onchange="e => Scan.Settings.CustomFFArguments = e.Value?.ToString() ?? string.Empty" />
    </label>
</section>

<section class="settings-section">
    <h2>Partial Clip Detection</h2>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.EnablePartialClipDetection"
               @onchange="e => Scan.Settings.EnablePartialClipDetection = (bool)e.Value!" />
        Enable partial clip detection (audio fingerprinting)
    </label>
    @if (Scan.Settings.EnablePartialClipDetection) {
        <label>
            Min clip / source ratio %
            <input type="number" min="1" max="100" step="0.1"
                   value="@((Scan.Settings.PartialClipMinRatio * 100).ToString(CultureInfo.InvariantCulture))"
                   @onchange="e => Scan.Settings.PartialClipMinRatio = ParseDouble(e.Value) / 100.0" />
        </label>
        <label>
            Min audio similarity %
            <input type="number" min="1" max="100" step="0.1"
                   value="@((Scan.Settings.PartialClipSimilarityThreshold * 100).ToString(CultureInfo.InvariantCulture))"
                   @onchange="e => Scan.Settings.PartialClipSimilarityThreshold = ParseDouble(e.Value) / 100.0" />
        </label>
    }
</section>

<section class="settings-section">
    <h2>Advanced Fingerprinting</h2>

    <h3>Sampling Window (Intro/Outro Skip)</h3>
    <label>
        Skip start (seconds)
        <input type="number" min="0" step="1"
               value="@Scan.Settings.SkipStartSeconds.ToString(CultureInfo.InvariantCulture)"
               @onchange="e => Scan.Settings.SkipStartSeconds = ParseDouble(e.Value)" />
    </label>
    <label>
        Skip start (%)
        <input type="number" min="0" max="50" step="0.1"
               value="@Scan.Settings.SkipStartPercent.ToString(CultureInfo.InvariantCulture)"
               @onchange="e => Scan.Settings.SkipStartPercent = (float)ParseDouble(e.Value)" />
    </label>
    <label>
        Skip end (seconds)
        <input type="number" min="0" step="1"
               value="@Scan.Settings.SkipEndSeconds.ToString(CultureInfo.InvariantCulture)"
               @onchange="e => Scan.Settings.SkipEndSeconds = ParseDouble(e.Value)" />
    </label>
    <label>
        Skip end (%)
        <input type="number" min="0" max="50" step="0.1"
               value="@Scan.Settings.SkipEndPercent.ToString(CultureInfo.InvariantCulture)"
               @onchange="e => Scan.Settings.SkipEndPercent = (float)ParseDouble(e.Value)" />
    </label>

    <h3>Scene-Aware Auto-Skip</h3>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.SceneAwareSkip"
               @onchange="e => Scan.Settings.SceneAwareSkip = (bool)e.Value!" />
        Auto-detect intro end via scene change detection
    </label>
    @if (Scan.Settings.SceneAwareSkip) {
        <label>
            Scene detection threshold (0–100)
            <input type="number" min="0" max="100" step="0.5"
                   value="@Scan.Settings.SceneDetectionThreshold.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.SceneDetectionThreshold = (float)ParseDouble(e.Value)" />
        </label>
        <label>
            Scene transitions to skip
            <input type="number" min="1" max="10" step="1"
                   value="@Scan.Settings.SceneSkipCount.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.SceneSkipCount = (int)ParseDouble(e.Value)" />
        </label>
    }

    <h3>I-Frame Timeline Fingerprint</h3>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.EnableIFrameFingerprint"
               @onchange="e => Scan.Settings.EnableIFrameFingerprint = (bool)e.Value!" />
        Enable I-frame sliding-window timeline comparison
    </label>
    @if (Scan.Settings.EnableIFrameFingerprint) {
        <label>
            Sample interval (seconds between samples)
            <input type="number" min="5" max="300" step="5"
                   value="@Scan.Settings.IFrameSampleIntervalSec.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.IFrameSampleIntervalSec = ParseDouble(e.Value)" />
        </label>
        <small style="color:var(--text-muted)">
            Both clips and sources are sampled at this density regardless of duration.
            A 9-min clip at 30 s → 18 samples. A 4-hour source at 30 s → 480 samples (capped).
            This is what makes sliding-window detection work across different video lengths.
        </small>
        <label>
            Max samples per video (hard ceiling)
            <input type="number" min="10" max="2000" step="50"
                   value="@Scan.Settings.MaxIFrameSamples.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.MaxIFrameSamples = (int)ParseDouble(e.Value)" />
        </label>
        <label>
            Min matching frame ratio % (of shorter video)
            <input type="number" min="5" max="100" step="1"
                   value="@((Scan.Settings.IFrameMatchPercent * 100).ToString(CultureInfo.InvariantCulture))"
                   @onchange="e => Scan.Settings.IFrameMatchPercent = (float)(ParseDouble(e.Value) / 100.0)" />
        </label>
        <label>
            Min consecutive matching frames (× interval = min matching duration)
            <input type="number" min="1" max="50" step="1"
                   value="@Scan.Settings.IFrameMinConsecutive.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.IFrameMinConsecutive = (int)ParseDouble(e.Value)" />
        </label>
        <label>
            Per-frame hash similarity threshold %
            <input type="number" min="50" max="100" step="1"
                   value="@((Scan.Settings.IFrameHashThreshold * 100).ToString(CultureInfo.InvariantCulture))"
                   @onchange="e => Scan.Settings.IFrameHashThreshold = (float)(ParseDouble(e.Value) / 100.0)" />
        </label>
    }

    <h3>Temporal Average Hash</h3>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.EnableTemporalAverageHash"
               @onchange="e => Scan.Settings.EnableTemporalAverageHash = (bool)e.Value!" />
        Enable tblend temporal average hash
    </label>
    @if (Scan.Settings.EnableTemporalAverageHash) {
        <label>
            Start position (seconds into video)
            <input type="number" min="0" step="10"
                   value="@Scan.Settings.TemporalAverageHashStartSec.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.TemporalAverageHashStartSec = ParseDouble(e.Value)" />
        </label>
        <label>
            Window duration (seconds)
            <input type="number" min="5" max="300" step="5"
                   value="@Scan.Settings.TemporalAverageHashWindowSec.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.TemporalAverageHashWindowSec = ParseDouble(e.Value)" />
        </label>
    }

    <h3>MPEG-7 Signature</h3>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.EnableMpeg7Signature"
               @onchange="e => Scan.Settings.EnableMpeg7Signature = (bool)e.Value!" />
        Enable MPEG-7 temporal video signature matching
    </label>

    <h3>SSIM Second-Pass Verification</h3>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.EnableSsimVerification"
               @onchange="e => Scan.Settings.EnableSsimVerification = (bool)e.Value!" />
        Enable SSIM verification for borderline matches
    </label>
    @if (Scan.Settings.EnableSsimVerification) {
        <label>
            Verify when similarity ≥ % (lower bound of gray zone)
            <input type="number" min="50" max="99" step="1"
                   value="@((Scan.Settings.SsimVerificationMinSim * 100).ToString(CultureInfo.InvariantCulture))"
                   @onchange="e => Scan.Settings.SsimVerificationMinSim = (float)(ParseDouble(e.Value) / 100.0)" />
        </label>
        <label>
            Verify when similarity ≤ % (upper bound of gray zone)
            <input type="number" min="50" max="100" step="1"
                   value="@((Scan.Settings.SsimVerificationMaxSim * 100).ToString(CultureInfo.InvariantCulture))"
                   @onchange="e => Scan.Settings.SsimVerificationMaxSim = (float)(ParseDouble(e.Value) / 100.0)" />
        </label>
        <label>
            SSIM reject threshold (below this = reject match)
            <input type="number" min="0.5" max="1" step="0.01"
                   value="@Scan.Settings.SsimRejectThreshold.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.SsimRejectThreshold = (float)ParseDouble(e.Value)" />
        </label>
        <label>
            SSIM comparison window (seconds)
            <input type="number" min="1" max="60" step="1"
                   value="@Scan.Settings.SsimWindowSeconds.ToString(CultureInfo.InvariantCulture)"
                   @onchange="e => Scan.Settings.SsimWindowSeconds = ParseDouble(e.Value)" />
        </label>
    }
</section>

<section class="settings-section">
    <h2>WebUI Thumbnails</h2>
    <label>
        <input type="checkbox"
               checked="@WebSettings.AutoLoadThumbnails"
               @onchange="e => WebSettings.AutoLoadThumbnails = (bool)e.Value!" />
        Automatically load thumbnails on results page
    </label>
    <label>
        Thumbnail width (px) — lower = less memory, more pixelated
        <input type="number" min="48" max="960" step="48"
               value="@WebSettings.ThumbnailWidth"
               @onchange="e => WebSettings.ThumbnailWidth = Math.Clamp(ParseInt(e.Value), 48, 960)" />
    </label>
    <label>
        JPEG quality (10–95) — lower = smaller files, more artifacts
        <input type="number" min="10" max="95" step="5"
               value="@WebSettings.ThumbnailJpegQuality"
               @onchange="e => WebSettings.ThumbnailJpegQuality = Math.Clamp(ParseInt(e.Value), 10, 95)" />
    </label>
</section>

<section class="settings-section">
    <h2>Database</h2>
    <label>
        <input type="checkbox"
               checked="@Scan.Settings.IncludeNonExistingFiles"
               @onchange="e => Scan.Settings.IncludeNonExistingFiles = (bool)e.Value!" />
        Scan against non-existing files (compare database entries whose files have been deleted or moved)
    </label>
    <label>
        Custom database folder
        <input type="text"
               value="@Scan.Settings.CustomDatabaseFolder"
               @onchange="e => Scan.Settings.CustomDatabaseFolder = e.Value?.ToString() ?? string.Empty" />
    </label>
    <label>
        Database checkpoint interval (minutes, 0 = disabled)
        <input type="number" min="0" max="60"
               value="@Scan.Settings.DatabaseCheckpointIntervalMinutes"
               @onchange="e => Scan.Settings.DatabaseCheckpointIntervalMinutes = ParseInt(e.Value)" />
    </label>

    <h3>Maintenance</h3>
    <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
        <button @onclick="CleanDatabase" disabled="@_dbBusy">Clean Database</button>
        @if (!_confirmClear) {
            <button class="danger" @onclick="() => _confirmClear = true" disabled="@_dbBusy">Clear Database</button>
        }
        else {
            <span style="color:var(--danger-color,#d33);">This will delete ALL stored data. Are you sure?</span>
            <button class="danger" @onclick="ClearDatabase">Yes, clear</button>
            <button @onclick="() => _confirmClear = false">Cancel</button>
        }
    </div>
    @if (_dbMsg != null) {
        <p class="@(_dbMsgIsError ? "aborted-msg" : "done-msg")" style="margin:0.25rem 0;">@_dbMsg</p>
    }
</section>

@code {
    string? _saveMsg;
    bool _saveFailed;
    bool _dbBusy;
    bool _confirmClear;
    string? _dbMsg;
    bool _dbMsgIsError;

    void SaveSettings() {
        bool ok = Scan.SaveSettings();
        _saveMsg = ok ? "Settings saved." : "Failed to save settings.";
        _saveFailed = !ok;
        _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => {
            _saveMsg = null;
            StateHasChanged();
        }));
    }

    async Task CleanDatabase() {
        _dbBusy = true;
        _dbMsg = null;
        try {
            int removed = await Scan.CleanDatabaseAsync();
            _dbMsg = $"Cleanup complete — {removed} entry(ies) removed.";
            _dbMsgIsError = false;
        }
        catch (Exception ex) {
            _dbMsg = $"Cleanup failed: {ex.Message}";
            _dbMsgIsError = true;
        }
        _dbBusy = false;
        DismissDbMsg();
    }

    async Task ClearDatabase() {
        _confirmClear = false;
        _dbBusy = true;
        _dbMsg = null;
        try {
            await Scan.ClearDatabaseAsync();
            _dbMsg = "Database cleared.";
            _dbMsgIsError = false;
        }
        catch (Exception ex) {
            _dbMsg = $"Clear failed: {ex.Message}";
            _dbMsgIsError = true;
        }
        _dbBusy = false;
        DismissDbMsg();
    }

    void DismissDbMsg() =>
        _ = Task.Delay(5000).ContinueWith(_ => InvokeAsync(() => {
            _dbMsg = null;
            StateHasChanged();
        }));

    // Culture-safe parsers: handle both comma and dot as decimal separator
    static string Normalize(object? v) =>
        (v?.ToString() ?? "0").Replace(',', '.');

    static float ParseFloat(object? v) =>
        float.TryParse(Normalize(v), NumberStyles.Float, CultureInfo.InvariantCulture, out var r) ? r : 0f;

    static double ParseDouble(object? v) =>
        double.TryParse(Normalize(v), NumberStyles.Float, CultureInfo.InvariantCulture, out var r) ? r : 0.0;

    static int ParseInt(object? v) =>
        int.TryParse(Normalize(v).Split('.')[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out var r) ? r : 0;

    static byte ParseByte(object? v) =>
        byte.TryParse(Normalize(v).Split('.')[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out var r) ? r : (byte)0;
}
